# Copy to .env — same values as week 1, plus two optional worker settings.
# NEVER commit a real key.

# From https://console.x.ai (you set this up in week 1).
XAI_API_KEY=

# Grok chat model (OpenAI SDK). Check https://docs.x.ai for current names.
CHAT_MODEL=grok-4

# xAI TTS voice_id (native /v1/tts endpoint — NOT a model name).
# Built-in voices: ara, eve, leo, rex, sal — check https://docs.x.ai.
TTS_VOICE=

# --- Worker (optional) ----------------------------------------------------
# The email-drafting worker can use a different (e.g. cheaper) model than the
# voice path — nobody is waiting on it. Defaults to CHAT_MODEL if unset.
WORKER_MODEL=

# Where the worker "sends" work orders (written into the .eml headers).
MAINTENANCE_EMAIL=oncall@kindredpm.example

# --- Optional ---------------------------------------------------------------
XAI_BASE_URL=https://api.x.ai/v1
