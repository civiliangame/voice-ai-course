# Copy this file to .env and fill it in. `.env` is read by server.py at startup.
# NEVER commit a real key.

# --- Required for the cascade (echo mode works with none of these set) -------

# From https://console.x.ai — create the key AND make sure billing is set up.
XAI_API_KEY=

# --- Grok chat model ----------------------------------------------------------
# The "brain" step uses the OpenAI SDK. Model names rot faster than course
# handouts — check the live models page at https://docs.x.ai (Lecture 1, Slide
# 13). The grok-4 family is current as of week 1.
CHAT_MODEL=grok-4

# --- Text-to-speech voice -----------------------------------------------------
# xAI TTS is a NATIVE endpoint (POST /v1/tts), not the OpenAI SDK, and it takes
# a voice_id — NOT a model name. Built-in voices (case-insensitive):
#   ara, eve, leo, rex, sal   (check https://docs.x.ai for the current list)
# Speech-to-text (POST /v1/stt) needs no model or voice — leave nothing to set.
TTS_VOICE=

# --- Optional ------------------------------------------------------------------
XAI_BASE_URL=https://api.x.ai/v1
