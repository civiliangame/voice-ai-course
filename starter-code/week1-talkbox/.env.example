# Copy this file to .env and fill it in. `.env` is read by server.py at startup.
# NEVER commit a real key.

# --- Required for the cascade (echo mode works with none of these set) -------

# From https://console.x.ai — create the key AND make sure billing is set up.
XAI_API_KEY=

# --- Model names --------------------------------------------------------------
# Model names rot faster than course handouts. Check the live models page at
# https://docs.x.ai before filling these in (Lecture 1, Slide 13).
# The server gives you a friendly error naming the missing variable if you skip one.

# Grok text model for the "brain" step (the grok-4 family is current as of week 1).
CHAT_MODEL=grok-4

# Speech-to-text model (audio in -> transcript out). Find the exact name on docs.x.ai.
STT_MODEL=

# Text-to-speech model + voice (reply text in -> audio out). Find both on docs.x.ai.
TTS_MODEL=
TTS_VOICE=

# --- Optional ------------------------------------------------------------------
XAI_BASE_URL=https://api.x.ai/v1
